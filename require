#!/usr/bin/env python3
"""Install development and monorepo package dependencies.

Standalone entrypoint for CI and fresh environments. Imports only
``scripts.require.core``, which uses the stdlib and does not depend on other
``scripts`` modules or on dev packages such as ``tomli`` until they are needed
(after ``requirements-dev.txt`` is installed, or via a one-off ``tomli`` bootstrap
on Python 3.10).
"""

from __future__ import annotations

import sys
from pathlib import Path

ROOT_DIR = Path(__file__).resolve().parent

if str(ROOT_DIR) not in sys.path:
    sys.path.insert(0, str(ROOT_DIR))

from scripts.require.core import main  # noqa: E402

if __name__ == "__main__":
    main()
